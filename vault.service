[Unit]
Description=Vault v5 — Gunicorn
After=network.target

[Service]
User=kopo
Group=kopo
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
WorkingDirectory=/home/kopo/BarnOS/Monolith/Code
Environment="VAULT_COOKIE_SECURE=true"
ExecStart=/home/kopo/BarnOS/Monolith/Code/venv/bin/gunicorn \
    --config /home/kopo/BarnOS/Monolith/Code/gunicorn.conf.py \
    server:app
Restart=on-failure
RestartSec=5
KillMode=mixed
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
